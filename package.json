{
  "name": "mcp-watchdog",
  "displayName": "MCP Watchdog",
  "description": "Automatic keepalive and reconnection for MCP servers",
  "version": "0.1.5",
  "publisher": "mcp-watchdog",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model context protocol",
    "keepalive",
    "reconnect",
    "monitor",
    "health",
    "cursor",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vaibhav11123/mcp-watchdog"
  },
  "bugs": {
    "url": "https://github.com/vaibhav11123/mcp-watchdog/issues"
  },
  "homepage": "https://github.com/vaibhav11123/mcp-watchdog#readme",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": ["AI", "Other"],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mcpWatchdog.showStatus",
        "title": "MCP Watchdog: Show Server Status"
      },
      {
        "command": "mcpWatchdog.reconnectAll",
        "title": "MCP Watchdog: Reconnect All Servers"
      },
      {
        "command": "mcpWatchdog.reconnectServer",
        "title": "MCP Watchdog: Reconnect Server..."
      },
      {
        "command": "mcpWatchdog.reconnectOne",
        "title": "MCP Watchdog: Reconnect Server"
      },
      {
        "command": "mcpWatchdog.focusServersView",
        "title": "MCP Watchdog: Open Servers View"
      },
      {
        "command": "mcpWatchdog.openMcpConfig",
        "title": "MCP Watchdog: Open MCP Config"
      },
      {
        "command": "mcpWatchdog.showOutput",
        "title": "MCP Watchdog: Show Output Log"
      },
      {
        "command": "mcpWatchdog.refresh",
        "title": "MCP Watchdog: Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "mcpWatchdog.refresh",
          "when": "view == mcpWatchdog.overview || view == mcpWatchdog.servers",
          "group": "navigation@1"
        },
        {
          "command": "mcpWatchdog.reconnectAll",
          "when": "view == mcpWatchdog.overview || view == mcpWatchdog.servers",
          "group": "navigation@2"
        },
        {
          "command": "mcpWatchdog.openMcpConfig",
          "when": "view == mcpWatchdog.overview || view == mcpWatchdog.servers",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "mcpWatchdog.reconnectOne",
          "when": "view == mcpWatchdog.servers && viewItem == mcpWatchdogServer",
          "group": "inline"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "mcpWatchdog.getStarted",
        "title": "Get started with MCP Watchdog",
        "description": "Monitor MCP server health from the activity bar—not the Extensions panel.",
        "steps": [
          {
            "id": "openServersView",
            "title": "Open the dashboard",
            "description": "The live UI is in the **activity bar** (left icon strip): **Overview** dashboard + **Servers** list—not inside **Extensions**.\n\n[Open MCP Watchdog](command:mcpWatchdog.focusServersView)",
            "media": {
              "image": "images/screenshot-servers-view.png",
              "altText": "MCP Watchdog Servers tree in the sidebar"
            },
            "completionEvents": ["onView:mcpWatchdog.overview"]
          },
          {
            "id": "addMcpConfig",
            "title": "Add MCP config",
            "description": "Use **.cursor/mcp.json** (Cursor) or **.vscode/mcp.json** (VS Code). Cursor often uses a `mcpServers` block.\n\n[Open or create MCP config](command:mcpWatchdog.openMcpConfig)",
            "completionEvents": ["onCommand:mcpWatchdog.openMcpConfig"]
          },
          {
            "id": "statusBar",
            "title": "Check the status bar",
            "description": "When servers are monitored, the bottom-right status bar shows **MCP: healthy/total**.\n\n[Show server status](command:mcpWatchdog.showStatus)",
            "media": {
              "image": "images/screenshot-status-bar.png",
              "altText": "MCP Watchdog status bar indicator"
            },
            "completionEvents": ["onCommand:mcpWatchdog.showStatus"]
          }
        ]
      }
    ],
    "viewsWelcome": [
      {
        "view": "mcpWatchdog.overview",
        "contents": "**MCP Watchdog** monitors your MCP servers.\n\n[Open a folder](command:workbench.action.openFolder)\n\nThen add **.cursor/mcp.json** or **.vscode/mcp.json**.\n\n[Create MCP config](command:mcpWatchdog.openMcpConfig)"
      },
      {
        "view": "mcpWatchdog.servers",
        "contents": "Per-server list with latency and reconnect.\n\n[Open Overview](command:mcpWatchdog.overview.focus)\n\n[Create MCP config](command:mcpWatchdog.openMcpConfig)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mcp-watchdog",
          "title": "MCP Watchdog",
          "icon": "images/icon.png"
        }
      ]
    },
    "views": {
      "mcp-watchdog": [
        {
          "id": "mcpWatchdog.overview",
          "name": "Overview",
          "type": "webview",
          "contextualTitle": "MCP health dashboard"
        },
        {
          "id": "mcpWatchdog.servers",
          "name": "Servers",
          "contextualTitle": "MCP servers (health)"
        }
      ]
    },
    "configuration": {
      "title": "MCP Watchdog",
      "properties": {
        "mcpWatchdog.pingIntervalMs": {
          "type": "number",
          "default": 30000,
          "description": "How often to ping each MCP server (ms). Default: 30000 (30s)"
        },
        "mcpWatchdog.maxRetries": {
          "type": "number",
          "default": 5,
          "description": "Max reconnection attempts before marking server as failed"
        },
        "mcpWatchdog.initialBackoffMs": {
          "type": "number",
          "default": 1000,
          "description": "Initial backoff delay before first reconnect attempt (ms)"
        },
        "mcpWatchdog.backoffMultiplier": {
          "type": "number",
          "default": 1.5,
          "description": "Backoff multiplier (e.g. 1.5 → 1s, 1.5s, 2.25s, ...)"
        },
        "mcpWatchdog.maxBackoffMs": {
          "type": "number",
          "default": 30000,
          "description": "Maximum backoff delay between retries (ms)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "compile": "tsc --noEmit",
    "smoke": "node scripts/smoke-connect.mjs",
    "test": "npm run compile && npm run build && npm run smoke && node scripts/test-integration.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/vscode": "^1.105.0",
    "esbuild": "^0.20.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0"
  }
}
